# Application
NODE_ENV=development
HTTP_PORT=5001
BASE_URL=http://localhost:5001
USER_URL=http://localhost:5002
ADMIN_URL=http://localhost:5003
CORS_ORIGINS=http://localhost:5002,http://localhost:5003

# MongoDB
MONGO_URI=mongodb://localhost:27017/base-code

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_PREFIX=base-code:
REDIS_SERVER_TYPE=single
REDIS_TLS=

# Redis Queue
REDIS_QUEUE_DB=1
REDIS_QUEUE_USERNAME=
REDIS_QUEUE_USE_CLUSTER_MODE=false

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRATION=7d
JWT_ISSUER=base-code-api
JWT_AUDIENCE=base-code-clients

# Request Security
JSON_BODY_LIMIT=1mb
URLENCODED_BODY_LIMIT=1mb
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
UPLOAD_RATE_LIMIT_WINDOW_MS=600000
UPLOAD_RATE_LIMIT_MAX=60
BACKUP_RATE_LIMIT_WINDOW_MS=3600000
BACKUP_RATE_LIMIT_MAX=5

# File Upload
MAX_FILE_SIZE=104857600
UPLOAD_DIR=public/uploads
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1080
IMAGE_QUALITY=82

# Logging
LOG_LEVEL=debug


# Bật kiểm thử Google Sign-In thật (yêu cầu cấu hình google_oauth_client_id ở Settings)
TEST_REAL_GOOGLE=true

# Bật kiểm thử Gửi Email thật (yêu cầu cấu hình SMTP trong Admin settings)
TEST_REAL_EMAIL=true

# Queue Monitoring Dashboard Secret Token
BULL_BOARD_AUTH_TOKEN=local-secret-key

